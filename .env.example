# Copy this file to .env (for local seeding) and fill in real values.
# These same three values also need to be added in Vercel's project
# Settings -> Environment Variables (see README.md for the exact steps).

TURSO_DATABASE_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Any long random string — used to sign login session cookies (JWT).
SESSION_SECRET=replace-with-a-long-random-string

# --- Email notifications (Microsoft 365 SMTP) ---
# SMTP_USER must be a real mailbox in your Microsoft 365 tenant that has
# "Authenticated SMTP" enabled (check: M365 Admin Center -> Users -> [user]
# -> Mail -> Manage email apps -> Authenticated SMTP).
# If that mailbox has MFA enabled, SMTP_PASS must be an APP PASSWORD,
# not the normal login password (Security info -> Add method -> App password).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=notifications@yourcompany.com
SMTP_PASS=your-password-or-app-password
SMTP_FROM=notifications@yourcompany.com

# Used to build links inside notification emails (your live Vercel URL,
# no trailing slash). Leave blank locally if you don't have one yet.
APP_URL=https://your-project.vercel.app
